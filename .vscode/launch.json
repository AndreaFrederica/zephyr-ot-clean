{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Zephyr RV32 ELF (J-Link external)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "external",
      "gdbTarget": "localhost:2331",
      "executable": "${workspaceFolder}/walle_g_build/zephyr/zephyr.elf",
      "gdbPath": "D:/appdata/users/qwe17/zephyr-sdk-0.17.4/riscv64-zephyr-elf/bin/riscv64-zephyr-elf-gdb.exe",
      "showDevDebugOutput": "raw",
      "runToEntryPoint": "z_cstart",
      "overrideLaunchCommands": [
        "monitor halt",
        "load",
        "monitor halt"
      ]
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/Projects/zephyr-ot-clean/app/parking_lock_slave/src",
      "program": "d:/Projects/zephyr-ot-clean/app/parking_lock_slave/src/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}